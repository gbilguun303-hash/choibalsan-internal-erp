# Existing ERP settings
PORT=4000
APP_URL=http://localhost:4000
JWT_SECRET=<generate-a-random-secret-at-least-32-bytes>
INITIAL_USER_PASSWORD=<temporary-password-minimum-12-characters>
SEED_USER_PASSWORD=<temporary-seed-password-minimum-12-characters>

# OpenAI Responses API (existing ERP assistant)
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-4.1

# Local MCP authentication uses the existing ERP JWT.
MCP_AUTH_MODE=erp_jwt
MCP_TOOL_TIMEOUT_MS=8000
MCP_RATE_LIMIT_MAX=60
MCP_RATE_LIMIT_WINDOW_MS=60000
MCP_PUBLIC_URL=https://erp.example.com/mcp

# Production ChatGPT private connector authentication.
# MCP_AUTH_MODE=oauth
# MCP_OAUTH_ISSUER=https://your-tenant.example.com/
# MCP_OAUTH_AUDIENCE=https://erp.example.com/mcp
# MCP_OAUTH_JWKS_URL=https://your-tenant.example.com/.well-known/jwks.json
# MCP_OAUTH_USER_ID_CLAIM=https://erp.example.com/erp_user_id
# MCP_OAUTH_SCOPES=erp.read
# MCP_RESOURCE_DOCUMENTATION_URL=https://erp.example.com/docs/mcp

# Local MCP test
MCP_TEST_URL=http://localhost:4000/mcp
MCP_TEST_USER_ID=<active-erp-user-id>

# ChirpStack downlink control. Keep API token only on the backend.
CHIRPSTACK_API_URL=http://192.82.67.219:8090
CHIRPSTACK_API_TOKEN=<chirpstack-api-token>
IOT_DOWNLINK_FPORT=10
IOT_DOWNLINK_CONFIRMED=true
# ADW310 DO register 0x1036. ADW300 Node 2 uses model-based built-in DO1 register 0x01C2 payloads in routes/iot.js.
IOT_DOWNLINK_ON_HEX=4d6f646275733a30303130313033363030303130323030303137453537
IOT_DOWNLINK_OFF_HEX=4d6f646275733a30303130313033363030303130323030303042463937
